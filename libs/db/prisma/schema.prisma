generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

//
// enums
//

enum workspaceRole {
  owner
  admin
  member
}

enum workspaceMemberStatus {
  pending
  active
  removed
}

enum fileType {
  drawing
  template
  sequence
  jobCard
  config
  table
}

enum eventType {
  drawing_data_extraction
  jobcard_generation
  plan_change
  manual_topup
  subscription
}

enum status {
  pending
  processing
  completed
  failed
}

// enum notificationType {
//   invite
//   role_changed
//   removed
// }

enum paymentProvider {
  phonepe
  stripe
}

//
// Core Entities
//

model user {
  id                String    @id @default(dbgenerated("auth.uid()")) @db.Uuid
  activeWorkspaceId String?   @db.Uuid
  name              String?
  email             String    @unique
  isDeleted         Boolean   @default(false)
  deletedAt         DateTime?

  activeWorkspace workspace? @relation(fields: [activeWorkspaceId], references: [id])

  memberships workspaceMember[]
  files       file[]
  events      event[]
  // Notification notification[]
}

model workspace {
  id            String    @id @default(uuid()) @db.Uuid
  planId        String?   @db.Uuid
  name          String    @unique
  credits       Float     @default(0)
  jobCardsCount Int       @default(0)
  thumbnail     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime? @default(now())

  plan plan? @relation(fields: [planId], references: [id])

  members         workspaceMember[]
  files           file[]
  events          event[]
  // Notification    notification[]
  workspaceUsages workspaceUsage[]
  // users           user[]
  user            user[]
}

model workspaceUsage {
  id          String @id @default(uuid()) @db.Uuid
  workspaceId String @db.Uuid

  periodStart DateTime
  periodEnd   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace workspace @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, periodStart, periodEnd])
}

model plan {
  id             String    @id @default(uuid()) @db.Uuid
  name           String    @unique
  maxWorkspaces  Int       @default(1)
  maxStorage     Int       @default(340)
  monthlyCredits Int       @default(0)
  features       Json      @default("{}")
  price          Float     @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime? @default(now())

  workspaces workspace[]
}

//
// Files
//

model file {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @db.Uuid
  userId      String    @db.Uuid
  name        String
  path        String
  type        fileType
  data        Json?
  thumbnail   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @default(now())

  workspace workspace @relation(fields: [workspaceId], references: [id])
  user      user      @relation(fields: [userId], references: [id])
  events    event[]
}

//
// Events (Transactions)
//

model event {
  id           String    @id @default(uuid()) @db.Uuid
  workspaceId  String    @db.Uuid
  userId       String    @db.Uuid
  fileId       String?   @db.Uuid
  type         eventType
  description  String    @default("")
  creditChange Float?    @default(0)
  balanceAfter Float?
  status       status    @default(pending)
  progress     Float?    @default(0)
  errorData    Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now())

  workspace workspace @relation(fields: [workspaceId], references: [id])
  File      file?     @relation(fields: [fileId], references: [id])
  user      user      @relation(fields: [userId], references: [id])
}

