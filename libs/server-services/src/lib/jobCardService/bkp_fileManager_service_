import fs from 'fs/promises';
import { randomUUID } from 'crypto';

import { FileStorageService } from '@prodgenie/libs/supabase';
import { FileService } from './file.service.js';

import { PdfService } from './pdf.service.js';
import { ThumbnailService } from './thumbnail.service.js';

export class FileManager {
  async saveAsPDF(html: string, jobCardNumber: string) {
    return PdfService.generatePDF(html, jobCardNumber);
  }

  async uploadJobCard(filePath: string, user: any, workspace: any) {
    const buffer = await fs.readFile(filePath);
    const fileName = filePath.split('/').pop();

    const file: Express.Multer.File = {
      id: randomUUID(),
      fieldname: 'file',
      originalname: fileName!,
      encoding: '7bit',
      mimetype: 'application/pdf',
      size: buffer.length,
      destination: '',
      filename: fileName!,
      path: filePath,
      buffer,
    };

    const jobCard = await FileService.uploadFile(
      [file],
      'jobCard',
      user,
      workspace
    );
    const thumbBuffer = await ThumbnailService.generate(file, 'jobCard');
    const thumb: Express.Multer.File = {
      fieldname: 'file',
      originalname: `${jobCard[0].id}_thumbnail.png`,
      encoding: '7bit',
      mimetype: 'image/jpeg',
      size: thumbBuffer.length,
      buffer: thumbBuffer,
      destination: '',
      filename: '',
      path: '',
    };
    await ThumbnailService.set(thumb, jobCard[0].id, user, workspace);
    return await FileStorageService.getSignedUrl(jobCard[0].path);
  }
}
